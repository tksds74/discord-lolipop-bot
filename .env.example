DISCORD_BOT_TOKEN=your_discord_bot_token_here

SSH_HOST=your.lolipop.host
SSH_PORT=22
SSH_USER=admin

# ローカル実行: 鍵ファイルのパスを指定
SSH_KEY_PATH=/path/to/private_key
# ホスティング等でファイルを置けない場合: 鍵の中身を直接環境変数に設定 (SSH_KEY_PATHと排他)
# SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"

# パスフレーズ付き鍵の場合のみ設定
# SSH_KEY_PASSPHRASE=

# known_hostsファイルのパス(未設定の場合ホスト鍵検証は無効化。本番では設定推奨)
# SSH_KNOWN_HOSTS=/path/to/known_hosts

PERMISSION_CONFIG_PATH=./permissions.json
